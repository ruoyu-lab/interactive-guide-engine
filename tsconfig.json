{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "paths": {
      "@guide/engine": ["./packages/engine/src"],
      "@guide/dom-renderer": ["./packages/dom-renderer/src"]
    }
  },
  "include": ["packages/**/*.ts", "examples/vue-demo/src/**/*.ts", "examples/vue-demo/src/**/*.vue"]
}
